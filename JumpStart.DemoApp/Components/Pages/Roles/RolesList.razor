@page "/roles"
@using JumpStart.Authorization.DTOs
@using JumpStart.Authorization.Clients
@inject IRolesApiClient RolesClient
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Roles</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Roles</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/user-permissions">
            <i class="bi bi-person-lock"></i> Direct User Permissions
        </a>
        <button class="btn btn-primary" @onclick="CreateNew">
            <i class="bi bi-plus-circle"></i> Create Role
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

@if (loading)
{
    <p><em>Loading roles...</em></p>
}
else if (roles != null)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Scope</th>
                    <th>Permissions</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in roles.OrderBy(r => r.Name))
                {
                    <tr>
                        <td>@role.Name</td>
                        <td>@role.Description</td>
                        <td>
                            @if (role.TenantId.HasValue)
                            {
                                <span class="badge bg-info">Tenant-owned</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Global</span>
                            }
                        </td>
                        <td>@role.Permissions.Count</td>
                        <td>
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => Manage(role.Id)">
                                    <i class="bi bi-shield-lock"></i> Manage
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(role.Id)">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(role)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!roles.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No roles found. Create one to get started.
        </div>
    }
}

@if (showDeleteConfirmation && roleToDelete != null)
{
    <JumpStart.DemoApp.Components.Shared.ConfirmationModal
        Title="Delete Role"
        ConfirmButtonText="Delete"
        ConfirmButtonClass="btn-danger"
        OnClose="HandleDeleteModalClose">
        <Message>
            Are you sure you want to delete the role '@roleToDelete.Name'? This cannot be undone.
        </Message>
    </JumpStart.DemoApp.Components.Shared.ConfirmationModal>
}

@code {
    private IEnumerable<RoleDto>? roles;
    private bool loading = true;
    private string? errorMessage;
    private string? successMessage;
    private bool showDeleteConfirmation = false;
    private RoleDto? roleToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
    }

    private async Task LoadRoles()
    {
        loading = true;
        errorMessage = null;
        try
        {
            var result = await RolesClient.GetAllAsync();
            roles = result.Items;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load roles: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void CreateNew() => Navigation.NavigateTo("/roles/new");

    private void Edit(Guid id) => Navigation.NavigateTo($"/roles/edit/{id}");

    private void Manage(Guid id) => Navigation.NavigateTo($"/roles/{id}/manage");

    private void ConfirmDelete(RoleDto role)
    {
        roleToDelete = role;
        showDeleteConfirmation = true;
    }

    private async Task DeleteConfirmed()
    {
        if (roleToDelete == null) return;

        showDeleteConfirmation = false;
        errorMessage = null;
        successMessage = null;

        try
        {
            await RolesClient.DeleteAsync(roleToDelete.Id);
            successMessage = $"Role '{roleToDelete.Name}' has been deleted.";
            await LoadRoles();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete role: {ex.Message}";
        }
        finally
        {
            roleToDelete = null;
        }
    }

    private async Task HandleDeleteModalClose(bool confirmed)
    {
        showDeleteConfirmation = false;

        if (confirmed)
        {
            await DeleteConfirmed();
        }
        else
        {
            roleToDelete = null;
        }
    }
}
