@page "/tenants"
@using JumpStart.MultiTenant.DTOs
@using JumpStart.MultiTenant.Clients
@inject ITenantsApiClient TenantsClient
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Tenants</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Tenants</h1>
    <button class="btn btn-primary" @onclick="CreateNew">
        <i class="bi bi-plus-circle"></i> Create Tenant
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

@if (loading)
{
    <p><em>Loading tenants...</em></p>
}
else if (tenants != null)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact Email</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tenant in tenants.OrderBy(t => t.Name))
                {
                    <tr>
                        <td>@tenant.Name</td>
                        <td>@tenant.ContactEmail</td>
                        <td>
                            @if (tenant.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(tenant.Id)">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(tenant)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!tenants.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No tenants found. Create one to get started.
        </div>
    }
}

@if (showDeleteConfirmation && tenantToDelete != null)
{
    <JumpStart.DemoApp.Components.Shared.ConfirmationModal
        Title="Delete Tenant"
        ConfirmButtonText="Delete"
        ConfirmButtonClass="btn-danger"
        OnClose="HandleDeleteModalClose">
        <Message>
            Are you sure you want to delete the tenant '@tenantToDelete.Name'? This cannot be undone.
        </Message>
    </JumpStart.DemoApp.Components.Shared.ConfirmationModal>
}

@code {
    private IEnumerable<TenantDto>? tenants;
    private bool loading = true;
    private string? errorMessage;
    private string? successMessage;
    private bool showDeleteConfirmation = false;
    private TenantDto? tenantToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadTenants();
    }

    private async Task LoadTenants()
    {
        loading = true;
        errorMessage = null;
        try
        {
            var result = await TenantsClient.GetAllAsync();
            tenants = result.Items;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load tenants: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void CreateNew() => Navigation.NavigateTo("/tenants/new");

    private void Edit(Guid id) => Navigation.NavigateTo($"/tenants/edit/{id}");

    private void ConfirmDelete(TenantDto tenant)
    {
        tenantToDelete = tenant;
        showDeleteConfirmation = true;
    }

    private async Task DeleteConfirmed()
    {
        if (tenantToDelete == null) return;

        showDeleteConfirmation = false;
        errorMessage = null;
        successMessage = null;

        try
        {
            await TenantsClient.DeleteAsync(tenantToDelete.Id);
            successMessage = $"Tenant '{tenantToDelete.Name}' has been deleted.";
            await LoadTenants();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete tenant: {ex.Message}";
        }
        finally
        {
            tenantToDelete = null;
        }
    }

    private async Task HandleDeleteModalClose(bool confirmed)
    {
        showDeleteConfirmation = false;

        if (confirmed)
        {
            await DeleteConfirmed();
        }
        else
        {
            tenantToDelete = null;
        }
    }
}
